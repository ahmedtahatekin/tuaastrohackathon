<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flareance | Uzay Hava Durumu & Kariyer Rehberi</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Orbitron', monospace;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #0a0a0a 100%);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* Yıldız Arka Planı */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image:
                radial-gradient(2px 2px at 20px 30px, #ffffff, transparent),
                radial-gradient(1px 1px at 90px 40px, #ffffff, transparent),
                radial-gradient(2px 2px at 200px 20px, #ffffff, transparent);
            background-repeat: repeat;
            background-size: 300px 200px;
            animation: starsTwinkle 20s linear infinite;
            z-index: -1;
        }

        @keyframes gradientShift { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        @keyframes starsTwinkle { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

        /* Navbar */
        .navbar {
            position: fixed;
            top: 0; left: 0; width: 100%;
            background: rgba(10, 10, 26, 0.98);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid #00ffff;
            padding: 15px 30px;
            z-index: 1002;
            box-shadow: 0 2px 20px rgba(0, 255, 255, 0.3);
        }

        .navbar-content { display: flex; justify-content: space-between; align-items: center; }
        .navbar h1 { color: #00ffff; text-shadow: 0 0 10px #00ffff; font-size: 1.5rem; }
        .navbar nav { display: flex; gap: 20px; }
        .navbar a {
            color: white; text-decoration: none; font-weight: 600;
            padding: 8px 16px; transition: 0.3s; border-radius: 8px;
        }
        .navbar a:hover { background: rgba(0, 255, 255, 0.2); color: #00ffff; }

        .bg-video {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            object-fit: cover; z-index: -2; opacity: 0.6;
        }

        /* Ruki Yan Panel */
        .ruki {
            display: flex; flex-direction: column; align-items: center;
            position: fixed; top: 60px; right: 0;
            height: calc(100vh - 60px); width: 340px;
            background: linear-gradient(180deg, rgba(31, 71, 163, 0.6) 0%, rgba(15, 35, 90, 0.5) 100%);
            border-left: 2px solid #00ffff; color: white; padding: 20px;
            z-index: 999; overflow-y: auto; text-align: center;
        }
        .ruki h2 { color: #00ffff; margin: 20px 0; text-shadow: 0 0 10px #00ffff; }
        .ruki img { max-width: 280px; border-radius: 15px; box-shadow: 0 0 20px rgba(0, 255, 255, 0.3); }

        /* Ana İçerik */
        .container {
            display: flex; flex-direction: column; align-items: center;
            padding: 120px 360px 20px 20px; width: 100%;
        }

        /* Kp Index Kartı */
        .kp-card {
            background: rgba(0, 255, 255, 0.1);
            border: 2px solid #00ffff;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 30px;
            width: 100%;
            max-width: 700px;
            text-align: center;
            box-shadow: 0 0 20px rgba(0, 255, 255, 0.2);
        }

        /* Olay Listesi */
        #ordered-list {
            list-style: none; display: flex; flex-direction: column; gap: 15px;
            padding: 30px; border-radius: 20px; border: 2px solid #00ffff;
            width: 100%; max-width: 700px; background: rgba(26, 26, 46, 0.5);
            backdrop-filter: blur(10px); counter-reset: list-counter;
        }

        #ordered-list li {
            background: linear-gradient(145deg, rgba(26, 26, 46, 0.8), rgba(40, 40, 70, 0.7));
            border-radius: 15px; border: 2px solid rgba(255, 0, 255, 0.6);
            padding: 20px 20px 20px 80px; transition: 0.3s;
            position: relative; cursor: pointer; display: flex; flex-direction: column;
        }

        #ordered-list li:hover {
            transform: scale(1.03); border-color: #00ffff;
            background: rgba(0, 255, 255, 0.1);
        }

        #ordered-list li::before {
            content: counter(list-counter);
            position: absolute; left: 20px; top: 50%; transform: translateY(-50%);
            background: #00ffff; color: #000; width: 40px; height: 40px;
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-weight: 900;
        }

        .activity-text { font-weight: bold; color: #fff; }
        .activity-time { font-size: 0.75rem; color: #00ffff; margin-top: 5px; }

        /* Tahmin Kartları */
        .forecast-container {
            display: flex; gap: 15px; margin-top: 30px; flex-wrap: wrap; justify-content: center;
        }
        .forecast-card {
            background: rgba(255, 0, 255, 0.1); border: 1px solid #ff00ff;
            padding: 15px; border-radius: 15px; width: 220px; text-align: center;
        }

        /* Modal */
        #modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); display: none; align-items: center;
            justify-content: center; z-index: 2000; backdrop-filter: blur(10px);
        }
        #modal-content {
            background: #0a0a1a; border: 2px solid #00ffff; padding: 40px;
            border-radius: 20px; max-width: 600px; text-align: center; position: relative;
        }
        #modal-close {
            position: absolute; top: 10px; right: 15px; background: none;
            border: none; color: #ff4444; font-size: 2rem; cursor: pointer;
        }

        @media (max-width: 768px) {
            .container { padding-right: 20px; }
            .ruki { display: none; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="navbar-content">
            <h1>🚀 Flareance</h1>
            <nav>
                <a href="/gunes-firtinalari-nedir">Güneş Fırtınaları Nedir?</a>
                <a href="https://www.nasa.gov" target="_blank">NASA</a>
            </nav>
        </div>
    </nav>

    <video autoplay muted loop class="bg-video">
        <source src="vide.mp4" type="video/mp4">
    </video>

    <div class="ruki">
        <h2>Hoşgeldiniz!</h2>
        <img src="/assets/rukimerak.png" alt="Ruki">
        <br>
        <p><strong>Selam, ben Ruki! Ben sizin gibi genç uzay tutkunlarına bu macerada yol göstereceğim. Güneş fırtınalarını ve uzayın gizemlerini beraber keşfedeceğiz...</strong></p>
    </div>

    <div class="container">
        <% if (currentStatus) { %>
            <div class="kp-card">
                <h3>📡 ANLIK MANYETİK AKTİVİTE</h3>
                <div style="font-size: 3rem; color: #ff00ff; margin: 10px 0;"><%= currentStatus.value %> Kp</div>
                <p>Durum: <%= currentStatus.value >= 5 ? '⚠️ Jeomanyetik Fırtına!' : '✅ Sakin' %></p>
                <small>Son Güncelleme: <%= new Date(currentStatus.time).toLocaleTimeString('tr-TR') %></small>
            </div>
        <% } %>

        <ol id="ordered-list">
            <h2 style="text-align: center; color: #00ffff; margin-bottom: 20px;">🛰️ GÜNCEL UZAY OLAYLARI</h2>
            <% recentEvents.forEach((event) => { %>
                <% 
                    let title = "";
                    let detail = "";
                    if(event.type === 'SOLAR_FLARE') {
                        title = `Güneş Patlaması (${event.intensity})`;
                        detail = `Şiddet: ${event.intensity} | Konum: ${event.location || 'Bilinmiyor'}`;
                    } else if(event.type === 'NOAA_ALERT') {
                        title = "NOAA Resmi Uyarısı";
                        detail = event.message.substring(0, 150) + "...";
                    } else if(event.type === 'KP_INDEX') {
                        title = `Manyetik Değişim: ${event.value} Kp`;
                        detail = `Tahmini Kp: ${event.estimated}`;
                    } else {
                        title = "Bilgi Mesajı";
                        detail = event.message;
                    }
                %>
                <li onclick="openModal('<%= title %>', '<%= detail %>')">
                    <span class="activity-text"><%= title %></span>
                    <span class="activity-time"><%= new Date(event.time).toLocaleString('tr-TR') %></span>
                </li>
            <% }) %>
        </ol>

        <div class="forecast-container">
            <% threeDayForecast.forEach((f) => { %>
                <div class="forecast-card">
                    <h4><%= f.date %></h4>
                    <div style="color: #00ffff; font-size: 1.2rem; margin: 5px 0;">G<%= f.geomagnetic %> Seviyesi</div>
                    <small><%= f.description %></small>
                </div>
            <% }) %>
        </div>
    </div>

    <div id="modal-overlay">
        <div id="modal-content">
            <button id="modal-close" onclick="closeModal()">✕</button>
            <h2 id="modal-title" style="color: #00ffff; margin-bottom: 15px;"></h2>
            <p id="modal-detail" style="line-height: 1.6;"></p>
            <button onclick="window.location.href='/careers'" style="margin-top:20px; padding: 10px 20px; background: #ff00ff; border:none; color:white; border-radius:10px; cursor:pointer; font-family: inherit; font-weight:bold;">
                Detaylı Rehbere Git
            </button>
        </div>
    </div>

    <script>
        function openModal(title, detail) {
            document.getElementById('modal-title').innerText = title;
            document.getElementById('modal-detail').innerText = detail;
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('modal-overlay').style.display = 'none';
        }

        window.onclick = function(event) {
            if (event.target == document.getElementById('modal-overlay')) {
                closeModal();
            }
        }
    </script>
</body>
</html>